# Google Chat target
GOOGLE_CHAT_URL=https://chat.google.com/app/chat/AAAA0hJPrYc
WATCH_USERS="
HQT - Jeremy, @JSanXiao
HQT - Conner, @Eason_Chung 
HQT - Shane, @shane_hsien 
HQT - Rosco, @rosco_07 
HQT - Ichih, @IchihBackend 
PHP - Richard, @richardl0_0"

# Scheduler
TZ=Asia/Taipei
CHECK_CRON=30 19 * * *
CHECK_CUTOFF=19:30

# Session path for browser storage state
SESSION_PATH=./state/google-session.json

# Optional credential login (headless)
# If both are set, bot will auto-login when session is missing/expired.
GOOGLE_EMAIL=
GOOGLE_PASSWORD=
AUTO_LOGIN_POST_WAIT_MS=15000

# Browser runtime
# Supported BROWSER_TYPE: chromium | firefox | webkit
BROWSER_TYPE=chromium
# Optional for chromium channel (for example: chrome, msedge)
BROWSER_CHANNEL=
# Optional path to system browser executable
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
BROWSER_EXECUTABLE_PATH=
# Optional remote Chromium DevTools endpoint.
# Docker Compose sets this to http://127.0.0.1:9222 automatically.
BROWSER_CDP_ENDPOINT=
BROWSER_HEADLESS=true
# Backward compatible key
PLAYWRIGHT_HEADLESS=true
CHAT_LOAD_TIMEOUT_MS=45000
CHAT_SCROLL_ROUNDS=24
CHAT_SCROLL_WAIT_MS=450

# Alerts
ALERT_ON_ERRORS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
